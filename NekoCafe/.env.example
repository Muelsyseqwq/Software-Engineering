# NekoCafe development profile
NEKO_PROFILE=dev

# Remote MySQL 8 connection. Do not commit real credentials in .env files.
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=nekocafe
MYSQL_USERNAME=nekocafe_app
MYSQL_PASSWORD=change_me
MYSQL_USE_SSL=false
MYSQL_ALLOW_PUBLIC_KEY_RETRIEVAL=false

# JWT secret must be changed in real environments and should be at least 32 chars.
JWT_SECRET=change_me_to_at_least_32_chars
JWT_EXPIRES_MINUTES=120

# Optional Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
