# NekoCafe development profile
NEKO_PROFILE=dev

# -----------------------------------------------------------------------------
# Docker Compose demo defaults
# -----------------------------------------------------------------------------
# These values are for local course demo only. Do not use them in production.
COMPOSE_MYSQL_DATABASE=nekocafe
COMPOSE_MYSQL_USERNAME=nekocafe_app
COMPOSE_MYSQL_PASSWORD=nekocafe_demo_password
COMPOSE_MYSQL_ROOT_PASSWORD=nekocafe_demo_root_password

# Host ports used by docker compose. Change these if your machine already uses
# 80, 3306, 6379, or 8080.
FRONTEND_PORT_HOST=80
BACKEND_PORT_HOST=8080
MYSQL_PORT_HOST=3306
REDIS_PORT_HOST=6379

# JWT secret must be changed in real environments and should be at least 32 chars.
JWT_SECRET=nekocafe_demo_jwt_secret_change_before_real_use_2026
JWT_EXPIRES_MINUTES=120

FLYWAY_ENABLED=true

# -----------------------------------------------------------------------------
# AI recommendation / DeepSeek settings
# -----------------------------------------------------------------------------
# Keep AI disabled by default so the stack can start without an API key.
# To enable DeepSeek in Docker Compose, set AI_ENABLED=true and provide AI_API_KEY
# in your local .env file. Never commit a real API key.
AI_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace_with_your_deepseek_api_key
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_SECONDS=20
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Manual / remote MySQL development configuration
# -----------------------------------------------------------------------------
# Spring Boot and Vite do not automatically read this root .env file when you
# start them manually. Export these variables in your shell or IDE run config.
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USE_SSL=false
MYSQL_ALLOW_PUBLIC_KEY_RETRIEVAL=false

# Optional Redis cache for manual local development
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend manual development. Docker Compose uses Nginx and the default /api.
VITE_API_BASE_URL=http://localhost:8080/api
